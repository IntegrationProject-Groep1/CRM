# RabbitMQ
# Option 1: Full URL - if the password contains special characters (#, ^, $, etc.)
#            they MUST be URL-encoded (e.g. # → %23, ^ → %5E, $ → %24).
# RABBITMQ_URL=amqp://user:p%40ssw0rd@host:port/

# Option 2 (recommended): Separate variables - special characters are handled automatically.
#
# Local development (against the shared team RabbitMQ broker):
#   RABBITMQ_HOST=integrationproject-2526s2-dag01.westeurope.cloudapp.azure.com
#   RABBITMQ_PORT=30000
#
# Production / Docker Compose (container-to-container, service name is the host):
#   RABBITMQ_HOST=rabbitmq
#   RABBITMQ_PORT=5672
#
# If another compose stack exposes RabbitMQ under a different service name (e.g. rabbitmq_broker):
#   RABBITMQ_HOST=rabbitmq_broker
#   RABBITMQ_PORT=5672
RABBITMQ_HOST=integrationproject-2526s2-dag01.westeurope.cloudapp.azure.com
RABBITMQ_PORT=30000
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Salesforce
SF_INSTANCE_URL=https://yourorg.my.salesforce.com
SF_CLIENT_ID=your_client_id
SF_CLIENT_SECRET=your_client_secret
SF_REFRESH_TOKEN=your_refresh_token
SF_ACCESS_TOKEN=your_access_token
SF_API_VERSION=v60.0
SF_CALLBACK_URL=https://oauth.pstmn.io/v1/callback

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=crm_demo
MYSQL_USER=crm_user
MYSQL_PASSWORD=crm_pass